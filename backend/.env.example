# code4u.ai — local development (copy values; never commit real secrets)
# Load: run uvicorn from this `backend/` directory so Pydantic finds this file.
# See: src/code4u/core/config.py (Settings)

# --- Core ---
ENVIRONMENT=development
DEBUG=false
HOST=0.0.0.0
PORT=8000

# --- Data stores (defaults match config.py; change if your services differ) ---
DATABASE_URL=postgresql+asyncpg://postgres:12345678@localhost:5432/code4ui
# Persist /auth/register + /auth/login users to Postgres (table code4u_auth_users)
AUTH_PERSIST_USERS=true
REDIS_URL=redis://localhost:6379/0
QDRANT_URL=http://localhost:6333

# --- Auth (use a long random string in production) ---
JWT_SECRET_KEY=change-me-use-openssl-rand-hex-32-or-similar-for-dev-only
# Optional alternate name read by AuthManager env provider:
# CODE4U_JWT_SECRET=

# --- LLM providers (uncomment and set when you call live APIs) ---
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# --- LLM module (prefix LLM_) — see src/code4u/ai_engine/llm/config.py ---
# LLM_PROVIDER=local
# LLM_OPENAI_API_KEY=
# LLM_ANTHROPIC_API_KEY=
# --- Misc (on native Windows you may use e.g. C:\\temp\\co  de4u-repos) ---
# REPO_CLONE_BASE=/tmp/code4u-repos
# AIR_GAPPED_MODE=false
# OLLAMA_BASE_URL=http://localhost:11434
# VLLM_BASE_URL=http://localhost:8000/v1
